            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Escova\",\n  \"description\": \"Escova modelada.\",\n  \"durationInMinutes\": 30,\n  \"price\": 40.00,\n  \"salonId\": \"{{salonId}}\"\n}"
