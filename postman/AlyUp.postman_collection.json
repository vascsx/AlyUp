    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "expiresInMinutes",
      "value": "60"
    },
    {
      "key": "masterEmail",
      "value": "admin@alyup.com"
    },
    {
      "key": "masterPassword",
      "value": "Password123!"
    },
    {
      "key": "salonId",
      "value": ""
    },
    {
      "key": "serviceId",
      "value": ""
    },
