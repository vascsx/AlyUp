              "mode": "raw",
              "raw": "{\n  \"name\": \"Corte Masculino Premium\",\n  \"description\": \"Corte com lavagem e finalização.\",\n  \"durationInMinutes\": 60,\n  \"price\": 79.90\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/services/{{serviceId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "services",
                "{{serviceId}}"
              ]
            },
            "description": "Atualiza um serviço existente. Permitido para SalonOwner do próprio salão ou Master."
