  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('accessToken', json.token);",
                  "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  if (json.expiresInMinutes) pm.collectionVariables.set('expiresInMinutes', String(json.expiresInMinutes));",
                  "  if (json.salonId) pm.collectionVariables.set('salonId', json.salonId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{masterEmail}}\",\n  \"password\": \"{{masterPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Auth",
                "login"
              ]
            },
            "description": "Autentica o usuario e salva automaticamente accessToken, refreshToken, expiresInMinutes e salonId quando disponivel."
          }
        },
        {
          "name": "Refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('accessToken', json.token);",
                  "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "  if (json.expiresInMinutes) pm.collectionVariables.set('expiresInMinutes', String(json.expiresInMinutes));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Auth",
                "refresh"
              ]
            },
            "description": "Troca o refresh token atual por um novo accessToken e um novo refreshToken."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Auth",
                "logout"
              ]
            },
            "description": "Revoga o refresh token atual. Apos logout, o refresh nao deve mais funcionar."
          }
        },
        {
          "name": "Register Client",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cliente Exemplo\",\n  \"email\": \"cliente@alyup.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/Auth/registerClient",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "Auth",
                "registerClient"
              ]
            },
            "description": "Cadastro publico de cliente. Nao requer JWT."
          }
        }
      ]
    },
    {
