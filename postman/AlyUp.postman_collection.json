              "path": [
                "api",
                "services"
              ],
              "query": [
                {
                  "key": "salonId",
                  "value": "{{salonId}}"
                },
                {
                  "key": "includeInactive",
                  "value": "false"
                }
              ]
            },
            "description": "Lista serviços. Para Client e Master, informe salonId. Para SalonOwner e Professional, o escopo do token será usado."
          }
        },
